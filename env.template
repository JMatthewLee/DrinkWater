# Supabase Configuration Template
# Copy this file to .env and replace the values with your actual Supabase credentials

# Your Supabase project URL (found in Settings > API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon key (found in Settings > API)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# App URL for password reset redirects (usually localhost for development)
EXPO_PUBLIC_APP_URL=exp://localhost:8082

# Instructions:
# 1. Create a Supabase project at https://supabase.com
# 2. Run the SQL schema from SUPABASE_INTEGRATION_README.md in the Supabase SQL Editor
# 3. Get your project URL and anon key from Settings > API
# 4. Copy this file to .env and replace the placeholder values
# 5. Restart your Expo development server
